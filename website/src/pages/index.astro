---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Minh-Ngoc" bare>
  <div class="frame">
    <h1 class="landing-title">
      My name is Minh-Ngoc, a government adviser and maker of things that make life more livable, fulfilling, and beautiful
    </h1>

    <p class="landing-body">
      During the day I am a strategy consultant for Dubai Culture &amp; Arts Authority, the 4th Middle Eastern government entity I've worked for. The rest of the time, I am whatever I want. This year, that means being:
    </p>

    <ul class="landing-list">
      <li>An aerial dancer</li>
      <li>A multi-disciplinary artist (this one is on-going)</li>
      <li><a href="/app-developer">An app developer</a></li>
      <li>An avid reader and book club attendee</li>
      <li>A writer</li>
    </ul>

    <hr class="divider" />
    <div class="link-row">
      <a href="/contact">Get in Touch</a>
      <a href="https://www.linkedin.com/" rel="me">My LinkedIn</a>
    </div>
    <hr class="divider" />

    <a class="scroll-cue" href="#selected-works">
      Scroll down for Selected Works <span class="scroll-cue-arrow" aria-hidden="true">↓</span>
    </a>
  </div>

  <section id="selected-works" class="works-section">
    <h2 class="works-heading">App(s) I Built</h2>

    <div class="shot-grid">
      <div class="shot-placeholder"></div>
      <div class="shot-placeholder shot-placeholder--small"></div>
    </div>

    <p class="works-label">VOYA</p>
    <p class="works-description">
      A paid travel opportunities directory for over-achievers like you and I. Upfront disclosure of support provided and no pay-to-apply BS.
    </p>
    <a class="button" href="https://apps-2347.onrender.com/" target="_blank" rel="noopener">Demo Voya</a>
  </section>
</BaseLayout>
